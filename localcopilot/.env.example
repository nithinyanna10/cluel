# LocalCopilot Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# LLM Provider: claude | openai | ollama | mock
LLM_PROVIDER=mock

# Anthropic Claude API key (only needed for LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=

# OpenAI API key (only needed for LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Model name
# Claude: claude-sonnet-4-6
# OpenAI: gpt-4o
# Ollama: llama3
MODEL_NAME=claude-sonnet-4-6

# Base URL for OpenAI-compatible or Ollama endpoints
LLM_BASE_URL=http://localhost:11434

# Transcription model size: tiny | base | small | medium | large-v2
TRANSCRIPTION_MODEL_SIZE=base

# Privacy settings
PRIVACY_MODE=false
LOCAL_ONLY_MODE=true

# Server
HOST=127.0.0.1
PORT=8787

# Database path (relative to backend/)
DATABASE_URL=sqlite:///./localcopilot.db
